# Skopiuj ten plik jako .env i uzupełnij wartości
# cp .env.example .env

# Dane SMTP (np. Gmail: smtp.gmail.com, port 587)
# Dla Gmaila użyj "hasła do aplikacji": konto Google → Bezpieczeństwo → Hasła do aplikacji
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=michal.harciarek.ovb@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx

# Na ten adres trafią wiadomości z formularza
MAIL_TO=kontakt@mihara.pl

# Dozwolone origin (adres frontendu w produkcji, np. https://mihara.pl)
ALLOWED_ORIGIN=*

# Port serwera
PORT=3000
